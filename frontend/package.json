    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-table": "^8.16.0",
    "axios": "^1.6.8",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.372.0",
    "plotly.js": "^2.29.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.3",
    "react-plotly.js": "^2.6.0",
    "reactflow": "^11.11.4",
