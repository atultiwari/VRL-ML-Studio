# VRL ML Studio — Environment Variables
# Copy this file to .env and adjust as needed

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true

# Frontend (Vite)
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# Projects storage directory (absolute path or relative to backend/)
VRL_PROJECTS_DIR=~/vrl-projects

# Studio version
VRL_STUDIO_VERSION=1.0.0
