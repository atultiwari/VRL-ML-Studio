# VRL ML Studio — Environment Variables
# Copy this file to .env and adjust as needed.
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │ TWO DEPLOYMENT MODES                                                    │
# │                                                                         │
# │ 1. LOCAL DEV (docker-compose.yml)                                       │
# │    Frontend on :3000, backend on :8000, both with hot reload.           │
# │    → docker compose up --build                                          │
# │                                                                         │
# │ 2. VPS / PRODUCTION (docker-compose.prod.yml)                           │
# │    Frontend served as static files via nginx on :80.                    │
# │    Nginx proxies /api/* and /ws to the backend internally.              │
# │    → docker compose -f docker-compose.prod.yml up -d --build            │
# └──────────────────────────────────────────────────────────────────────────┘

# ── Backend ──────────────────────────────────────────────────────────────────

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# true for local dev (auto-reload on code changes), false for production
BACKEND_RELOAD=true

# ── Frontend (Vite build-time variables) ─────────────────────────────────────
#
# LOCAL DEV: frontend connects directly to backend on separate ports.
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
#
# VPS / PRODUCTION: leave these empty or set to /api.
# The nginx proxy handles routing — the frontend auto-derives URLs from
# the page origin (e.g. https://demo.example.com/api, wss://demo.example.com/ws).
# These are set as build args in docker-compose.prod.yml, so you don't need
# to change them here for production.

# ── Storage ──────────────────────────────────────────────────────────────────

# Directory where all tenant project data is stored.
# Each user gets an isolated workspace under tenants/{tenant_id}/ automatically.
VRL_PROJECTS_DIR=~/vrl-projects

# ── CORS (local dev only) ──────────────────────────────────────────────��────
#
# In production with nginx, CORS is not needed (same-origin).
# In local dev, localhost:3000 and localhost:8000 are pre-configured.
# Add extra origins here if you access the dev backend from a different URL.
# CORS_ORIGINS=http://192.168.1.100:3000

# ── Version ──────────────────────────────────────────────────────────────────

VRL_STUDIO_VERSION=1.0.0
